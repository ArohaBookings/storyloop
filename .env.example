# STORYLOOP — Environment Variables
# Copy this file to .env.local and fill in every value.

# ---- SUPABASE ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ---- AI (at least one required — OpenAI recommended) ----
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ---- STRIPE ----
STRIPE_SECRET_KEY=sk_live_or_test_your_storyloop_account_key
STRIPE_WEBHOOK_SECRET=whsec_set_after_creating_storyloop_webhook_endpoint

# Stripe price IDs (create 4 prices: Educator/Centre x AUD/NZD)
STRIPE_PRICE_EDUCATOR_AUD=price_storyloop_educator_aud
STRIPE_PRICE_EDUCATOR_NZD=price_storyloop_educator_nzd
STRIPE_PRICE_CENTRE_AUD=price_storyloop_centre_aud
STRIPE_PRICE_CENTRE_NZD=price_storyloop_centre_nzd

# ---- APP ----
NEXT_PUBLIC_APP_URL=https://your-storyloop-domain.example

# ---- CRON (for monthly usage reset) ----
CRON_SECRET=generate_a_random_32_byte_hex_string

# ---- ADMIN ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_PLAIN=
# Escape each $ in bcrypt hashes so Next.js does not treat them as env expansion.
ADMIN_PASSWORD_HASH=\$2a\$12\$replace_me_with_your_bcrypt_hash
ADMIN_JWT_SECRET=generate_a_random_32_byte_hex_string
